{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm ci",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/cases/:path*", "destination": "https://overload-opacity-connector.ngrok-free.dev/cases/:path*" },
    { "source": "/artifacts/:path*", "destination": "/api/artifact?p=:path*" },
    { "source": "/health", "destination": "https://overload-opacity-connector.ngrok-free.dev/health" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
